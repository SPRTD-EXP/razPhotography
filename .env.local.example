# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Calendly (Bookings page)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username

# Stripe (Prints / e-commerce)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prodigi (Print fulfillment)
# Use sandbox key for testing: https://api.sandbox.prodigi.com
# Switch to live key for production: https://api.prodigi.com
PRODIGI_API_KEY=your_prodigi_api_key
