# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Cal.com Atoms (Bookings page)
# 1. Create OAuth client at app.cal.com/settings/platform/oauth-clients/create
# 2. Visit /api/cal/authorize to get your access + refresh tokens
NEXT_PUBLIC_CAL_OAUTH_CLIENT_ID=your_client_id
NEXT_PUBLIC_CAL_USERNAME=your_cal_username
NEXT_PUBLIC_CAL_EVENT_SLUG=photography-session
CAL_OAUTH_CLIENT_SECRET=your_client_secret
CAL_ACCESS_TOKEN=obtained_after_oauth_flow
CAL_REFRESH_TOKEN=obtained_after_oauth_flow

# Stripe (Prints / e-commerce)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Prodigi (Print fulfillment)
# Sandbox key for testing, swap for live key when ready
PRODIGI_API_KEY=your_prodigi_api_key
